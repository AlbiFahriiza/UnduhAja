---
import { type Lang, localizePath, getOppositeLang, createTranslator, delocalizePath, getDictionary } from '@/i18n/utils';
import { HeaderAuth } from '@/components/react/HeaderAuth';

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = createTranslator(lang);
const dict = getDictionary(lang);
const oppositeLang = getOppositeLang(lang);

const navItems = [
  { label: t('nav.faq'), href: localizePath(lang, '/faq') },
  { label: t('nav.blog'), href: localizePath(lang, '/blog') },
  { label: t('nav.about'), href: localizePath(lang, '/about') },
];

const homeHref = localizePath(lang, '/');
const currentPathDelocalized = delocalizePath(Astro.url.pathname);
const oppositeLangHref = localizePath(oppositeLang, currentPathDelocalized);

const authLabels = dict.auth;
---

<header class="header" data-header>
  <div class="container header__inner">
    <a href={homeHref} class="header__logo" aria-label="UnduhAja">
      <img
        src="/icons/logo-header.png"
        srcset="/icons/logo-header.png 1x, /icons/logo-header@2x.png 2x"
        width="32"
        height="32"
        alt="UnduhAja"
        class="header__logo-img"
        loading="eager"
      />
      <span class="header__logo-text">UnduhAja</span>
    </a>

    <nav class="header__nav" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="header__nav-link"
          data-nav-link
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header__actions">
      <a
        href={oppositeLangHref}
        class="header__lang-toggle"
        aria-label={`Switch to ${oppositeLang === 'id' ? 'Bahasa Indonesia' : 'English'}`}
        data-lang-toggle
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M2 12h20" />
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
        </svg>
        <span>{oppositeLang.toUpperCase()}</span>
      </a>

      <button
        class="header__theme-toggle"
        aria-label="Toggle dark mode"
        data-theme-toggle
      >
        <svg class="header__icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
        </svg>
        <svg class="header__icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9c0 0 0 0 0 0z" />
        </svg>
      </button>

      <HeaderAuth client:load lang={lang} labels={authLabels} />

      <button
        class="header__menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div class="header__mobile-menu" data-mobile-menu hidden>
    <nav class="header__mobile-nav" aria-label="Mobile navigation">
      {navItems.map((item) => (
        <a href={item.href} class="header__mobile-link" data-mobile-link>
          {item.label}
        </a>
      ))}
      <a href={localizePath(lang, '/')} class="header__mobile-cta">
        {t('nav.getStarted')}
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: color-mix(in srgb, var(--color-bg) 90%, transparent);
    border-bottom: 1px solid var(--color-border);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .header[data-scrolled="true"] {
    background: var(--color-surface);
    box-shadow: var(--shadow-xs);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--space-6);
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--font-weight-extrabold);
    font-size: var(--font-size-lg);
    letter-spacing: var(--tracking-tight);
    transition: opacity var(--duration-fast) ease;
  }

  .header__logo:hover {
    opacity: 0.85;
  }

  .header__logo-img {
    width: 32px;
    height: 32px;
    display: block;
    object-fit: contain;
    flex-shrink: 0;
  }

  .header__logo-text {
    line-height: 1;
  }

  .header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    margin-left: auto;
    margin-right: var(--space-4);
  }

  .header__nav-link {
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    border-radius: var(--radius-md);
    transition: color var(--duration-fast) ease, background-color var(--duration-fast) ease;
  }

  .header__nav-link:hover {
    color: var(--color-text);
    background: var(--color-surface-sunken);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .header__lang-toggle,
  .header__theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-secondary);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
  }

  .header__lang-toggle:hover,
  .header__theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
    background: var(--color-surface-sunken);
  }

  .header__icon-sun {
    display: block;
  }

  .header__icon-moon {
    display: none;
  }

  [data-theme='dark'] .header__icon-sun {
    display: none;
  }

  [data-theme='dark'] .header__icon-moon {
    display: block;
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-md);
    transition: background-color var(--duration-fast) ease, transform var(--duration-fast) ease;
  }

  .header__cta:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .header__menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
  }

  .header__menu-toggle:hover {
    background: var(--color-surface-sunken);
  }

  .header__mobile-menu {
    display: none;
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: var(--space-4) 0;
  }

  .header__mobile-menu[data-open="true"] {
    display: block;
  }

  .header__mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: 0 var(--space-6);
  }

  .header__mobile-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    border-radius: var(--radius-md);
    transition: all var(--duration-fast) ease;
  }

  .header__mobile-link:hover {
    color: var(--color-text);
    background: var(--color-surface-sunken);
  }

  .header__mobile-cta {
    display: block;
    margin-top: var(--space-3);
    padding: var(--space-3) var(--space-4);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    text-decoration: none;
    text-align: center;
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-md);
  }

  @media (max-width: 880px) {
    .header__nav,
    .header__cta,
    .header__lang-toggle span {
      display: none;
    }

    .header__menu-toggle {
      display: inline-flex;
    }

    .header__lang-toggle {
      padding: var(--space-2);
    }
  }
</style>

<script>
  // Header interactions
  const header = document.querySelector<HTMLElement>('[data-header]');
  const menuToggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const mobileMenu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const themeToggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');

  // Sticky header background on scroll
  if (header) {
    const handleScroll = () => {
      header.dataset.scrolled = window.scrollY > 8 ? 'true' : 'false';
    };
    handleScroll();
    window.addEventListener('scroll', handleScroll, { passive: true });
  }

  // Mobile menu toggle
  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      const isOpen = mobileMenu.dataset.open === 'true';
      mobileMenu.dataset.open = String(!isOpen);
      mobileMenu.hidden = isOpen;
      menuToggle.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  // Theme toggle
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme') ?? 'light';
      const next = current === 'light' ? 'dark' : 'light';

      // Add transition class
      html.classList.add('theme-transition');
      html.setAttribute('data-theme', next);
      localStorage.setItem('unduhaja-theme', next);

      // Remove transition class after animation
      setTimeout(() => html.classList.remove('theme-transition'), 300);
    });
  }
</script>
