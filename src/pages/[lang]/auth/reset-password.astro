---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { ResetPasswordForm } from '@/components/react/ResetPasswordForm';
import { type Lang, createTranslator, getDictionary, localizePath } from '@/i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'id' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const dict = getDictionary(lang);
const t = createTranslator(lang);
const authLabels = dict.auth;
const isID = lang === 'id';
---

<BaseLayout
  title={`${authLabels.forgot} — UnduhAja`}
  description={authLabels.forgot}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>{authLabels.forgot}</h1>
        <p class="subtitle">{isID ? 'Atur kata sandi baru untuk akun kamu' : 'Set a new password for your account'}</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container container-narrow">
        <ResetPasswordForm client:load lang={lang} labels={authLabels} />
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-12);
    background:
      radial-gradient(ellipse at top, var(--color-primary-subtle) 0%, transparent 60%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }

  .page-header h1 {
    margin: 0 0 var(--space-4);
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    max-width: 560px;
    margin: 0 auto;
  }

  .page-content {
    padding: var(--space-16) 0;
  }
</style>
