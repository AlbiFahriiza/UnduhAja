---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { DownloaderTool } from '@/components/react/DownloaderTool';
import { type Lang, createTranslator, getDictionary } from '@/i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'id' } },
    { params: { lang: 'en' } },
  ];
}

interface Props {
  lang: Lang;
}

const { lang } = Astro.params as Props;
const dict = getDictionary(lang);
const t = createTranslator(lang);

// Check for auth error in URL (from /api/auth/callback redirect)
const authError = Astro.url.searchParams.get('auth');
const authErrorCode = Astro.url.searchParams.get('code');
const authErrorMessages: Record<string, { id: string; en: string }> = {
  access_denied: { id: 'Login dibatalkan', en: 'Login cancelled' },
  invalid_request: { id: 'Request tidak valid', en: 'Invalid request' },
  server_error: { id: 'Server error', en: 'Server error' },
  temporarily_unavailable: { id: 'Layanan sementara tidak tersedia', en: 'Service temporarily unavailable' },
  no_code: { id: 'Kode auth tidak ditemukan', en: 'Auth code not found' },
  config_error: { id: 'Konfigurasi server bermasalah', en: 'Server configuration error' },
  token_expired: { id: 'Token kedaluwarsa, coba lagi', en: 'Token expired, try again' },
  invalid_token: { id: 'Token tidak valid', en: 'Invalid token' },
  token_used: { id: 'Token sudah dipakai', en: 'Token already used' },
  rate_limited: { id: 'Terlalu banyak percobaan, coba nanti', en: 'Too many attempts, try later' },
  exchange_failed: { id: 'Gagal menukar token', en: 'Token exchange failed' },
  unknown_error: { id: 'Error tidak diketahui', en: 'Unknown error' },
};
const authErrorText = authError === 'error' && authErrorCode
  ? (authErrorMessages[authErrorCode]?.[lang] ?? authErrorMessages.unknown_error[lang])
  : null;

const isID = lang === 'id';

const translations = {
  input: dict.input,
  preview: dict.preview,
  quality: dict.quality,
  download: dict.download,
  errors: dict.errors,
  toast: dict.toast,
  auth: dict.auth,
};
---

<BaseLayout
  title={`${t('hero.title')} — UnduhAja`}
  description={t('hero.description')}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <section class="hero">
      <div class="container hero__inner">
        <div class="hero__badge">
          <span class="hero__badge-dot"></span>
          {t('hero.badge')}
        </div>

        {authErrorText && (
          <div class="auth-error-banner" role="alert">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>{authErrorText}</span>
          </div>
        )}

        <h1 class="hero__title">{t('hero.title')}</h1>
        <p class="hero__subtitle">{t('hero.subtitle')}</p>
        <p class="hero__description">{t('hero.description')}</p>

        <div class="hero__tool" id="downloader">
          <DownloaderTool client:load lang={lang} translations={translations} />
        </div>

        <div class="hero__trust">
          <div class="hero__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
              <polyline points="22 4 12 14.01 9 11.01" />
            </svg>
            <span>{lang === 'id' ? 'Tanpa iklan' : 'No ads'}</span>
          </div>
          <div class="hero__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <span>{lang === 'id' ? 'Privasi aman' : 'Privacy safe'}</span>
          </div>
          <div class="hero__trust-item">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z" />
            </svg>
            <span>{lang === 'id' ? 'Sangat cepat' : 'Super fast'}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="what-is">
      <div class="container">
        <div class="what-is__content">
          <span class="what-is__label">{isID ? 'Apa itu UnduhAja?' : 'What is UnduhAja?'}</span>
          <h2 class="what-is__title">
            {isID
              ? 'Platform downloader video modern untuk pengguna Indonesia.'
              : 'Modern video downloader platform for Indonesian users.'}
          </h2>
          <p class="what-is__desc">
            {isID
              ? 'UnduhAja adalah layanan web yang memungkinkan Anda mengunduh video dari YouTube dan TikTok dengan mudah, cepat, dan gratis. Dirancang dengan fokus pada privasi pengguna — tanpa iklan, tanpa tracking, tanpa penyimpanan riwayat unduhan. Tempel URL video, pilih kualitas (hingga 1080p60 untuk video, MP3 320kbps untuk audio), dan unduh langsung ke perangkat Anda.'
              : 'UnduhAja is a web service that allows you to download videos from YouTube and TikTok easily, fast, and free. Designed with a focus on user privacy — no ads, no tracking, no download history storage. Paste a video URL, choose quality (up to 1080p60 for video, MP3 320kbps for audio), and download directly to your device.'}
          </p>
          <div class="what-is__stats">
            <div class="what-is__stat">
              <strong>2</strong>
              <span>{isID ? 'Platform didukung' : 'Platforms supported'}</span>
            </div>
            <div class="what-is__stat">
              <strong>8+</strong>
              <span>{isID ? 'Pilihan kualitas' : 'Quality options'}</span>
            </div>
            <div class="what-is__stat">
              <strong>0</strong>
              <span>{isID ? 'Iklan & tracker' : 'Ads & trackers'}</span>
            </div>
            <div class="what-is__stat">
              <strong>24/7</strong>
              <span>{isID ? 'Selalu online' : 'Always online'}</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="container">
        <div class="features__grid">
          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polygon points="23 7 16 12 23 17 23 7" />
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2" />
              </svg>
            </div>
            <h3>YouTube & TikTok</h3>
            <p>{lang === 'id'
              ? 'Dukungan penuh untuk video YouTube (termasuk Shorts) dan TikTok. Cukup tempel URL, sisanya urusan kami.'
              : 'Full support for YouTube videos (including Shorts) and TikTok. Just paste the URL, we handle the rest.'}</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
              </svg>
            </div>
            <h3>{lang === 'id' ? 'Kualitas Pilihan' : 'Quality Choice'}</h3>
            <p>{lang === 'id'
              ? 'Dari 144p hingga 1080p60. Atau ekstrak audio MP3/M4A dengan bitrate maksimal dari sumber.'
              : 'From 144p to 1080p60. Or extract MP3/M4A audio at maximum source bitrate.'}</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
              </svg>
            </div>
            <h3>{lang === 'id' ? 'Privasi Utama' : 'Privacy First'}</h3>
            <p>{lang === 'id'
              ? 'Tidak ada riwayat, tidak ada tracking, tidak ada cookie. URL kamu diproses langsung, tidak disimpan.'
              : 'No history, no tracking, no cookies. Your URL is processed on-the-fly, never stored.'}</p>
          </div>

          <div class="feature-card">
            <div class="feature-card__icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
            </div>
            <h3>{lang === 'id' ? 'Cepat & Modern' : 'Fast & Modern'}</h3>
            <p>{lang === 'id'
              ? 'Dibangun dengan teknologi terkini. Animasi spring physics yang halus, performa kelas enterprise.'
              : 'Built with modern tech. Smooth spring physics animations, enterprise-grade performance.'}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SEO: How It Works section (>250 words target, H1 keywords in body) -->
    <section class="how-it-works">
      <div class="container">
        <h2 class="section-title">{isID ? 'Cara Mengunduh Video Tanpa Ribet' : 'How to Download Videos Without the Hassle'}</h2>
        <p class="section-subtitle">
          {isID
            ? 'UnduhAja dirancang untuk membuat proses download video YouTube dan TikTok menjadi sesederhana mungkin. Ikuti 3 langkah mudah berikut untuk mengunduh video favorit kamu.'
            : 'UnduhAja is designed to make downloading YouTube and TikTok videos as simple as possible. Follow these 3 easy steps to download your favorite videos.'}
        </p>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-number">1</div>
            <h3>{isID ? 'Tempel URL Video' : 'Paste Video URL'}</h3>
            <p>
              {isID
                ? 'Salin link video dari YouTube atau TikTok, lalu tempelkan ke kotak input di atas. Kamu bisa menggunakan keyboard shortcut Ctrl+V atau klik tombol "Tempel" untuk membaca clipboard otomatis. UnduhAja juga mendukung drag and drop URL langsung dari address bar browser.'
                : 'Copy the video link from YouTube or TikTok, then paste it into the input box above. You can use the keyboard shortcut Ctrl+V or click the "Paste" button to auto-read your clipboard. UnduhAja also supports drag and drop URLs directly from your browser address bar.'}
            </p>
          </div>
          <div class="step-card">
            <div class="step-number">2</div>
            <h3>{isID ? 'Pilih Kualitas' : 'Choose Quality'}</h3>
            <p>
              {isID
                ? 'Setelah video terdeteksi, preview card akan menampilkan thumbnail, judul, channel, dan durasi video. Pilih kualitas video yang diinginkan dari dropdown custom — mulai dari 144p hingga 1080p60. Untuk audio saja, pilih format MP3 320kbps atau M4A 256kbps AAC.'
                : 'Once the video is detected, a preview card will display the thumbnail, title, channel, and video duration. Choose your desired video quality from the custom dropdown — from 144p up to 1080p60. For audio only, choose MP3 320kbps or M4A 256kbps AAC format.'}
            </p>
          </div>
          <div class="step-card">
            <div class="step-number">3</div>
            <h3>{isID ? 'Klik Unduh' : 'Click Download'}</h3>
            <p>
              {isID
                ? 'Tekan tombol "Unduh Sekarang" dan file akan otomatis tersimpan ke perangkat kamu. Tidak perlu registrasi, tidak perlu install software, tidak perlu menonton iklan. Download video tanpa ribet langsung dari browser. Jika download manual diperlukan, tombol fallback muncul setelah 8 detik.'
                : 'Press the "Download Now" button and the file will automatically save to your device. No registration needed, no software to install, no ads to watch. Download videos without the hassle directly from your browser. If manual download is needed, a fallback button appears after 8 seconds.'}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SEO: FAQ preview + external links + social share -->
    <section class="seo-content">
      <div class="container">
        <div class="seo-content__grid">
          <div class="seo-content__main">
            <h2 class="section-title">{isID ? 'Tentang UnduhAja — Download Video Tanpa Ribet' : 'About UnduhAja — Download Videos Without the Hassle'}</h2>
            <p>
              {isID
                ? 'UnduhAja adalah platform downloader video modern yang dibuat khusus untuk pengguna Indonesia. Dengan UnduhAja, kamu bisa download video tanpa ribet dari YouTube dan TikTok dalam hitungan detik. Tidak seperti downloader lain yang penuh iklan popup dan redirect mencurigakan, UnduhAja menawarkan pengalaman bersih, cepat, dan aman.'
                : 'UnduhAja is a modern video downloader platform built specifically for Indonesian users. With UnduhAja, you can download videos without the hassle from YouTube and TikTok in seconds. Unlike other downloaders full of popup ads and suspicious redirects, UnduhAja offers a clean, fast, and safe experience.'}
            </p>
            <p>
              {isID
                ? 'Platform ini mendukung berbagai format dan kualitas video. Untuk video YouTube, kamu bisa memilih dari 144p hingga 1080p60 (Full HD 60fps). Untuk TikTok, video tanpa watermark tersedia dalam kualitas asli. Jika kamu hanya membutuhkan audio, UnduhAja bisa mengekstrak suara dari video YouTube dalam format MP3 dengan bitrate 320kbps atau M4A AAC 256kbps.'
                : 'The platform supports various video formats and qualities. For YouTube videos, you can choose from 144p up to 1080p60 (Full HD 60fps). For TikTok, no-watermark videos are available in original quality. If you only need audio, UnduhAja can extract sound from YouTube videos in MP3 format at 320kbps bitrate or M4A AAC at 256kbps.'}
            </p>
            <p>
              {isID
                ? 'Privasi pengguna adalah prioritas utama. UnduhAja tidak menyimpan riwayat unduhan, tidak menggunakan cookie tracking, tidak memasang analytics pihak ketiga, dan tidak menjual data ke siapapun. URL yang kamu tempelkan diproses secara real-time dan langsung dihapus dari memory server setelah unduhan selesai. Untuk informasi lebih lanjut, baca kebijakan privasi kami.'
                : 'User privacy is the top priority. UnduhAja does not store download history, does not use tracking cookies, does not install third-party analytics, and does not sell data to anyone. URLs you paste are processed in real-time and immediately deleted from server memory after download completes. For more information, read our privacy policy.'}
            </p>
            <p>
              {isID
                ? 'UnduhAja kompatibel dengan semua perangkat — desktop, tablet, dan mobile. Antarmuka responsif dengan dukungan dark mode memastikan pengalaman yang nyaman di kondisi pencahayaan apapun. Website ini juga installable sebagai Progressive Web App (PWA), sehingga kamu bisa menambahkannya ke home screen HP seperti aplikasi native.'
                : 'UnduhAja is compatible with all devices — desktop, tablet, and mobile. The responsive interface with dark mode support ensures a comfortable experience in any lighting condition. This website is also installable as a Progressive Web App (PWA), so you can add it to your phone home screen like a native app.'}
            </p>

            <!-- External links (SEO: outbound links to authority sites) -->
            <div class="external-links">
              <span class="external-links__label">{isID ? 'Platform yang didukung:' : 'Supported platforms:'}</span>
              <a href="https://www.youtube.com" target="_blank" rel="noopener noreferrer" class="external-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                YouTube
              </a>
              <a href="https://www.tiktok.com" target="_blank" rel="noopener noreferrer" class="external-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
                TikTok
              </a>
            </div>

            <!-- Social share buttons -->
            <div class="social-share">
              <span class="social-share__label">{isID ? 'Bagikan UnduhAja:' : 'Share UnduhAja:'}</span>
              <div class="social-share__buttons">
                <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(isID ? 'UnduhAja — Download Video Tanpa Ribet!' : 'UnduhAja — Download Videos Without the Hassle!')}&url=https://unduhaja.vercel.app`} target="_blank" rel="noopener noreferrer" class="social-share__btn" aria-label="Share on Twitter/X">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=https://unduhaja.vercel.app`} target="_blank" rel="noopener noreferrer" class="social-share__btn" aria-label="Share on Facebook">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="D24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href={`https://wa.me/?text=${encodeURIComponent('UnduhAja — Download Video Tanpa Ribet! https://unduhaja.vercel.app')}`} target="_blank" rel="noopener noreferrer" class="social-share__btn" aria-label="Share on WhatsApp">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                </a>
                <a href={`https://t.me/share/url?url=https://unduhaja.vercel.app&text=${encodeURIComponent('UnduhAja — Download Video Tanpa Ribet!')}`} target="_blank" rel="noopener noreferrer" class="social-share__btn" aria-label="Share on Telegram">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.139-5.061 3.345-.48.329-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .hero {
    padding: var(--space-20) 0 var(--space-16);
    background:
      radial-gradient(ellipse at top, var(--color-primary-subtle) 0%, transparent 60%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-6);
  }

  .auth-error-banner {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-error-subtle);
    color: var(--color-error);
    border: 1px solid var(--color-error-border);
    border-radius: var(--radius-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    max-width: 480px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
