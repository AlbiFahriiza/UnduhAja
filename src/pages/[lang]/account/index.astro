---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { AccountDashboard } from '@/components/react/AccountDashboard';
import { type Lang, createTranslator, getDictionary } from '@/i18n/utils';

export const prerender = false;

const lang: Lang = (Astro.url.pathname.split('/')[1] as Lang) || 'id';
const dict = getDictionary(lang);
const t = createTranslator(lang);
const authLabels = dict.auth;
---

<BaseLayout
  title={`${t('pages.account.title')} — UnduhAja`}
  description={t('pages.account.subtitle')}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>{t('pages.account.title')}</h1>
        <p class="subtitle">{t('pages.account.subtitle')}</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container container-narrow">
        <AccountDashboard client:load lang={lang} labels={authLabels} />
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-12);
    background: radial-gradient(ellipse at top, var(--color-primary-subtle) 0%, transparent 60%), var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }
  .page-header h1 { margin: 0 0 var(--space-4); }
  .subtitle {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    max-width: 560px;
    margin: 0 auto;
  }
  .page-content { padding: var(--space-16) 0; }
</style>
