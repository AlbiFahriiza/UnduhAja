---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { StatusDashboard } from '@/components/react/StatusDashboard';
import { type Lang, createTranslator } from '@/i18n/utils';

export const prerender = false;

const lang: Lang = (Astro.url.pathname.split('/')[1] as Lang) || 'id';
const t = createTranslator(lang);
const isID = lang === 'id';
---

<BaseLayout
  title={`${isID ? 'Status Layanan' : 'Service Status'} — UnduhAja`}
  description={isID ? 'Status real-time semua layanan UnduhAja' : 'Real-time status of all UnduhAja services'}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>{isID ? 'Status Layanan' : 'Service Status'}</h1>
        <p class="subtitle">{isID ? 'Monitor real-time kesehatan semua sistem UnduhAja' : 'Real-time monitoring of all UnduhAja systems'}</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container container-narrow">
        <StatusDashboard client:load lang={lang} />
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-12);
    background: radial-gradient(ellipse at top, var(--color-primary-subtle) 0%, transparent 60%), var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }
  .page-header h1 { margin: 0 0 var(--space-4); }
  .subtitle {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    max-width: 560px;
    margin: 0 auto;
  }
  .page-content { padding: var(--space-16) 0; }
</style>
