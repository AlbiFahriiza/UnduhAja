---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { type Lang, createTranslator, localizePath } from '@/i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'id' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = createTranslator(lang);
const isID = lang === 'id';

const releases = isID ? [
  {
    version: 'v1.0.0',
    date: '18 Juli 2026',
    badge: 'Stable',
    highlights: [
      'Rilis perdana UnduhAja — YouTube & TikTok downloader modern',
      'Bilingual ID/EN dengan URL prefix (/id/, /en/)',
      'Custom RK4 analytical spring engine (frame-rate independent)',
      'Animated placeholder cycling (TikTok URL → YouTube URL)',
      'Auth system (Email + Google OAuth) dengan Cloudflare Turnstile',
      '5-layer anti-abuse defense (Supabase Captcha + rate limit + honeypot + URL validation + IP blacklist)',
      'PWA support (manifest + service worker + 8 icon sizes)',
      'Dark mode toggle dengan smooth transition',
      '14 halaman bilingual (Landing, FAQ, About, Privacy, Terms, Blog, Reset Password)',
      'SEO lengkap (sitemap, robots.txt, JSON-LD structured data)',
    ],
  },
] : [
  {
    version: 'v1.0.0',
    date: 'July 18, 2026',
    badge: 'Stable',
    highlights: [
      'Initial release of UnduhAja — modern YouTube & TikTok downloader',
      'Bilingual ID/EN with URL prefix (/id/, /en/)',
      'Custom RK4 analytical spring engine (frame-rate independent)',
      'Animated placeholder cycling (TikTok URL → YouTube URL)',
      'Auth system (Email + Google OAuth) with Cloudflare Turnstile',
      '5-layer anti-abuse defense (Supabase Captcha + rate limit + honeypot + URL validation + IP blacklist)',
      'PWA support (manifest + service worker + 8 icon sizes)',
      'Dark mode toggle with smooth transition',
      '14 bilingual pages (Landing, FAQ, About, Privacy, Terms, Blog, Reset Password)',
      'Complete SEO (sitemap, robots.txt, JSON-LD structured data)',
    ],
  },
];
---

<BaseLayout
  title={`${t('pages.changelog.title')} — UnduhAja`}
  description={t('pages.changelog.subtitle')}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <section class="page-header">
      <div class="container">
        <h1>{t('pages.changelog.title')}</h1>
        <p class="subtitle">{t('pages.changelog.subtitle')}</p>
      </div>
    </section>

    <section class="page-content">
      <div class="container container-narrow">
        <div class="releases">
          {releases.map((release) => (
            <article class="release">
              <header class="release__header">
                <div class="release__meta">
                  <h2 class="release__version">{release.version}</h2>
                  <span class="release__badge">{release.badge}</span>
                </div>
                <time class="release__date">{release.date}</time>
              </header>
              <div class="release__body">
                <h3 class="release__section-title">
                  {isID ? 'Highlight Fitur' : 'Feature Highlights'}
                </h3>
                <ul class="release__list">
                  {release.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>

        <div class="cta-box">
          <h3>{isID ? 'Mulai pakai UnduhAja' : 'Start using UnduhAja'}</h3>
          <p>
            {isID
              ? 'Tempel URL YouTube atau TikTok favorit kamu dan rasakan pengalaman downloader modern.'
              : 'Paste your favorite YouTube or TikTok URL and experience a modern downloader.'}
          </p>
          <a href={localizePath(lang, '/')} class="btn-primary">
            {isID ? 'Mulai Mengunduh' : 'Start Downloading'}
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-20) 0 var(--space-12);
    background:
      radial-gradient(ellipse at top, var(--color-primary-subtle) 0%, transparent 60%),
      var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }
  .page-header h1 { margin: 0 0 var(--space-4); }
  .subtitle {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    max-width: 560px;
    margin: 0 auto;
  }
  .page-content { padding: var(--space-16) 0; }
  .releases { display: flex; flex-direction: column; gap: var(--space-8); }
  .release {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    transition: border-color var(--duration-fast) ease;
  }
  .release:hover { border-color: var(--color-primary-border); }
  .release__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border-subtle);
    margin-bottom: var(--space-5);
  }
  .release__meta { display: flex; align-items: center; gap: var(--space-3); }
  .release__version {
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    margin: 0;
    font-family: var(--font-mono);
  }
  .release__badge {
    padding: 4px var(--space-2);
    background: var(--color-success-subtle);
    color: var(--color-success);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .release__date {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-sm);
  }
  .release__section-title {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .release__list {
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    padding-left: var(--space-6);
    margin: 0;
  }
  .release__list li { margin-bottom: var(--space-2); }
  .cta-box {
    margin-top: var(--space-16);
    padding: var(--space-10);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-align: center;
  }
  .cta-box h3 {
    font-size: var(--font-size-xl);
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .cta-box p { color: var(--color-text-secondary); margin: 0 0 var(--space-6); }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-md);
    transition: background-color var(--duration-fast) ease, transform var(--duration-fast) ease;
  }
  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }
</style>
