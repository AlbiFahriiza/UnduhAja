  headline: post.title,
  description: post.excerpt,
  datePublished: post.date,
  author: { '@type': 'Person', name: post.author },
  publisher: { '@type': 'Organization', name: 'UnduhAja' },
};
---

<BaseLayout
  title={`${post.title} — UnduhAja`}
  description={post.excerpt}
  lang={lang}
>
  <Header lang={lang} />

  <main>
    <article class="blog-post">
      <div class="container container-narrow">
        <a href={localizePath(lang, '/blog')} class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12" />
            <polyline points="12 19 5 12 12 5" />
          </svg>
          <span>{isID ? 'Kembali ke Blog' : 'Back to Blog'}</span>
        </a>

        <header class="post-header">
          <div class="post-meta">
            <span class="post-tag">{post.tag}</span>
            <span class="post-date">
              {new Date(post.date).toLocaleDateString(isID ? 'id-ID' : 'en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
            <span class="post-reading">{post.readingTime}</span>
          </div>
          <h1 class="post-title">{post.title}</h1>
          <p class="post-excerpt">{post.excerpt}</p>
          <div class="post-author">
            <div class="post-author-avatar">AF</div>
            <div>
              <div class="post-author-name">{post.author}</div>
              <div class="post-author-role">{isID ? 'Founder & Developer' : 'Founder & Developer'}</div>
            </div>
          </div>
        </header>

        <div class="post-content" set:html={renderedContent} />

        <script type="application/ld+json" set:html={JSON.stringify(blogPostSchema)} />

        <footer class="post-footer">
          <div class="post-cta">
            <h3>{isID ? 'Siap mencoba?' : 'Ready to try?'}</h3>
            <p>{isID ? 'Tempel URL YouTube atau TikTok favorit Anda dan rasakan pengalaman downloader modern.' : 'Paste your favorite YouTube or TikTok URL and experience a modern downloader.'}</p>
            <a href={localizePath(lang, '/')} class="btn-primary">
              {isID ? 'Mulai Mengunduh' : 'Start Downloading'}
            </a>
          </div>
        </footer>
      </div>
    </article>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  .blog-post { padding: var(--space-16) 0; }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    margin-bottom: var(--space-8);
    transition: color var(--duration-fast) ease;
  }
  .back-link:hover { color: var(--color-primary); }

  .post-header { margin-bottom: var(--space-10); }
  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }
  .post-tag {
    padding: 4px var(--space-2);
    background: var(--color-primary-subtle);
    color: var(--color-primary);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
  .post-date, .post-reading {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-sm);
  }
  .post-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--font-weight-bold);
    color: var(--color-text);
    line-height: var(--line-height-tight);
    margin: 0 0 var(--space-4);
    letter-spacing: var(--tracking-tight);
  }
  .post-excerpt {
    color: var(--color-text-secondary);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    margin: 0 0 var(--space-6);
  }
  .post-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .post-author-avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-sm);
  }
  .post-author-name {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-sm);
  }
  .post-author-role {
    color: var(--color-text-tertiary);
    font-size: var(--font-size-xs);
  }

  .post-content {
    color: var(--color-text-secondary);
    font-size: var(--font-size-base);
    line-height: var(--line-height-loose);
  }
  .post-content :global(h2) {
    color: var(--color-text);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    margin: var(--space-10) 0 var(--space-4);
    line-height: var(--line-height-tight);
  }
  .post-content :global(h3) {
    color: var(--color-text);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    margin: var(--space-8) 0 var(--space-3);
  }
  .post-content :global(p) {
    margin: 0 0 var(--space-4);
  }
  .post-content :global(ul) {
    margin: 0 0 var(--space-4);
    padding-left: var(--space-6);
  }
  .post-content :global(li) {
    margin-bottom: var(--space-2);
  }
  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
  }
  .post-content :global(code) {
    background: var(--color-surface-sunken);
    padding: 2px var(--space-2);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.9em;
    color: var(--color-text);
  }

  .post-footer { margin-top: var(--space-16); }
  .post-cta {
    padding: var(--space-10);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-align: center;
  }
  .post-cta h3 {
    font-size: var(--font-size-xl);
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .post-cta p {
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6);
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
    border-radius: var(--radius-md);
    transition: all var(--duration-fast) ease;
  }
  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }
</style>
