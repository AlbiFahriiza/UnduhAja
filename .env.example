# ============================================
# UnduhAja v1.0.0 — Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# Site
PUBLIC_SITE_URL=https://unduhaja.vercel.app

# ============================================
# Supabase (Auth + DB + Edge Functions)
# ============================================
# From: Supabase Dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxx
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxx  # Personal access token for CLI
SUPABASE_PROJECT_REF=your-project-ref

# ============================================
# Cloudflare Workers (Cobalt API)
# ============================================
# After deploying Cobalt to Cloudflare Workers
COBALT_API_URL=https://api.unduhaja.workers.dev

# ============================================
# Cloudflare Turnstile (Anti-bot)
# ============================================
# From: https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAAA_xxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAA_xxxxxxxxxxxxxxxx

# ============================================
# Google Search Console (for OAuth verification)
# ============================================
# Get this from: https://www.google.com/webmasters/tools/
# Add property → URL prefix → https://your-domain.com
# Verify via HTML tag → copy the content="" value here
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ============================================
# Auth
# ============================================
AUTH_SECRET=your-random-32-char-secret-string

# ============================================
# Vercel
# ============================================
VERCEL=1
