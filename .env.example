# ============================================
# UnduhAja v1.0.0 — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your own values.
# Never commit your real .env file to git!

# ============================================
# Site
# ============================================
PUBLIC_SITE_URL=https://your-domain.com

# ============================================
# Supabase (Auth + Database + Edge Functions)
# ============================================
# Get these from: Supabase Dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Cloudflare Turnstile (Anti-bot protection)
# ============================================
# Get these from: https://dash.cloudflare.com → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key

# ============================================
# Google Search Console (Optional - for OAuth verification)
# ============================================
# Get this from: https://www.google.com/webmasters/tools/
# Add property → URL prefix → your domain
# Verify via HTML tag → copy the content="" value here
# Multiple codes: separate with comma
PUBLIC_GOOGLE_SITE_VERIFICATION=

# ============================================
# Auth
# ============================================
# Generate a random 32+ character string for JWT signing
AUTH_SECRET=generate-a-random-32-char-secret-here
